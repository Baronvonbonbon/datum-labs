# ~/.config/datum-relay/monitor.env  (OPTIONAL — defaults already match the live layout)
# Used by datum-monitor.service. All keys are optional; uncomment to override.
# RPC_URL=https://eth-rpc-testnet.polkadot.io
# MIN_GAS_PAS=50               # low-gas alert threshold per submitter
# QUEUE_BACKLOG=100            # relay queued-claims alert threshold
# CHAIN_STALL_CYCLES=5         # cycles of no new block -> chain.stalled alert
# MONITOR_INTERVAL=30          # seconds between cycles
# MONITOR_PORT=3500            # /metrics + /health (LOCAL)
# ALERT_WEBHOOK=https://...    # generic JSON {text} sink (Slack / ntfy / Discord-slack)
# ALERT_HEARTBEAT_MIN=60       # re-send still-firing issues every N min (0=off)
# RELAYS=diana=http://127.0.0.1:3400,frank=http://127.0.0.1:3410
# COSIGNERS=bob=http://127.0.0.1:3402,charlie=http://127.0.0.1:3411
# GAS_WATCH=diana=0xcA5668fB864Acab0aC7f4CFa73949174720b58D0,frank=0x92622970Bd48dD26c53bCCd09Aa6a0245dbc7620
