# --- DATUM indexer config ---
# Copy to .env and adjust. All values have sane defaults; everything here is optional.

# Paseo Hub eth-rpc gateway. Full-history log reads (unlike Pine's forward-only window).
RPC_URL=https://eth-rpc-testnet.polkadot.io

# Where to read contract addresses. Defaults to the sibling datum repo's alpha-core deploy.
# Point this at deployed-addresses.json for whichever network you're studying.
# Env-first resolution: set DATUM_GOVERNANCE_ROUTER to read every contract LIVE
# from the on-chain registry (auto-tracks upgrades; self-contained in production).
# Unset = take the router address + seed from the DATUM_ADDRESSES file below.
# DATUM_GOVERNANCE_ROUTER=0xAb22653cDcA7214636708721AeDAc289E8635e80
DATUM_ADDRESSES=../../datum/alpha-core/deployed-addresses.json

# First block to index. "auto" = head - BACKFILL_DEPTH. Set to the deploy block
# (alpha-core deployed 2026-05-23) for a complete study, else you only see recent history.
START_BLOCK=auto
BACKFILL_DEPTH=200000

# getLogs window size. Keep modest — the Paseo gateway rejects large ranges.
CHUNK_SIZE=2000

# Tail poll interval (ms). 12s ≈ 2 blocks at 6s/block.
POLL_INTERVAL_MS=12000

# SQLite file + HTTP port for the metrics server.
DB_PATH=data/datum.db
PORT=4319
