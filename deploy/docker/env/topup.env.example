# env/topup.env  (cp from this, chmod 600 — holds the master key)
# Master = a faucet-funded EOA that refills the relay submitters when they dip
# below the floor. The service warns in its log when the master itself runs low.
MASTER_PRIVATE_KEY=0x...
RPC_URL=https://eth-rpc-testnet.polkadot.io
# Submitters to keep funded (diana + frank relay-signers). Used by the compose command.
TOPUP_TARGETS=0xcA5668fB864Acab0aC7f4CFa73949174720b58D0,0x92622970Bd48dD26c53bCCd09Aa6a0245dbc7620
