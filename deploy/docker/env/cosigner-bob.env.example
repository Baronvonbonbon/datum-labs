# env/cosigner-bob.env  (cp from this, chmod 600 — holds bob's advertiser key)
ADVERTISER_PRIVATE_KEY=0x...             # bob's advertiser key — signs/refuses for bob's campaigns
HTTP_PORT=3402
HTTP_BIND=0.0.0.0                         # reachable by the relays on the docker network
RPC_URL=https://eth-rpc-testnet.polkadot.io
DATUM_GOVERNANCE_ROUTER=0xAb22653cDcA7214636708721AeDAc289E8635e80
# COSIGN_SECRET=        # optional HMAC; must equal the relay's ADVERTISER_COSIGNER_SECRET for this advertiser
# MAX_CPM_PLANCK=0      # refuse claims above this rate (0 = no cap)
