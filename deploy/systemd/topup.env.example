# ~/.config/datum-relay/topup.env  (chmod 600 — holds the master key)
# Used by datum-topup.service. The master is a faucet-funded EOA that refills the
# relay submitters when they dip below --min PAS. Faucet it generously; the service
# logs a loud warning when the master itself runs low (the signal to re-faucet).
MASTER_PRIVATE_KEY=0x...
RPC_URL=https://eth-rpc-testnet.polkadot.io
# Targets + thresholds (which accounts, min/to/reserve PAS, interval) are set in the
# unit's ExecStart — edit datum-topup.service to change them.
