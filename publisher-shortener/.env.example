# --- Tier-1 publisher: ad-supported URL shortener ---
# Copy to .env and set at least PUBLISHER_ADDRESS + RELAY_URL for real fills.

# Your on-chain publisher address (must be registered in DatumPublishers — see README).
# Left unset, the page still renders the no-extension house ad, but no real
# auction/settlement happens, so the indexer sees nothing.
PUBLISHER_ADDRESS=0x0000000000000000000000000000000000000000

# Your relay endpoint (the SDK POSTs clicks here; the relay co-signs + submits
# settlement). cp -r ../../datum/relay-bot.example ../../datum/relay-bot to run one.
RELAY_URL=http://localhost:3400

# Relay/settlement path: "publisher" | "dualsig" | "datumrelay".
RELAY_MODE=publisher

# Page tags the slot is auctioned against. A shortener is general-audience;
# crypto-web3 matches the currently-seeded campaigns. Comma-separated dimension:value.
TAGS=topic:crypto-web3,locale:en

# Ad slot format shown on the interstitial (leaderboard | medium-rectangle | large-rectangle | ...).
SLOT=medium-rectangle

# Seconds the visitor waits (ad dwell time) before "Continue" unlocks.
INTERSTITIAL_SECONDS=5

# Path to the DATUM SDK (served same-origin at /datum-sdk.js).
SDK_PATH=../../datum/sdk/datum-sdk.js

PORT=4320
DB_PATH=data/links.db
