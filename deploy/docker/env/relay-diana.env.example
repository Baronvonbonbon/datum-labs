# env/relay-diana.env  (cp from this, chmod 600 — holds the relay-signer key)
RELAY_PRIVATE_KEY=0x...                  # diana's publisher relay-signer key
HTTP_PORT=3400
HTTP_BIND=0.0.0.0                         # container-internal; fronted by cloudflared
RELAY_PUBLIC=1                            # reachable beyond loopback (behind the tunnel)
RPC_URL=https://eth-rpc-testnet.polkadot.io
DATUM_GOVERNANCE_ROUTER=0xAb22653cDcA7214636708721AeDAc289E8635e80
# Independent advertiser co-signers (gasless dual-sig) — keep ADVERTISER_PRIVATE_KEY EMPTY.
# Map keyed by advertiser address → cosigner service URL (docker DNS).
ADVERTISER_PRIVATE_KEY=
ADVERTISER_COSIGNERS={"0xfe091a42bce57f3f9acd92d21c8f9dbc4e5c7ce6":{"url":"http://cosigner-bob:3402"},"0x09ce34740bce52fb3caa4a2d50cc2fbad6f32c5b":{"url":"http://cosigner-charlie:3411"}}
CLAIM_BATCH_SIZE=1
MAX_INFLIGHT=25
# RELAY_HMAC_SECRET=          # optional; public /claim is rate-limited, HMAC not required for browser clients
# RATE_LIMIT_PER_IP=30  RATE_LIMIT_GLOBAL=300  RATE_LIMIT_WINDOW_MS=60000
