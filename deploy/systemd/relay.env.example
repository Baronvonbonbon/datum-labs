# ~/.config/datum-relay/<instance>.env  (chmod 600 — holds a private key)
# Used by datum-relay@<instance>.service.
RELAY_PRIVATE_KEY=0x...          # the publisher's relay-signer key
HTTP_PORT=3400                   # public claim API (tunnel-exposed)
ADMIN_PORT=3401                  # LOCAL-ONLY operator console (127.0.0.1)
RELAY_HMAC_SECRET=...            # gate /claim+/click for trusted testers
RELAY_CONFIG=/home/USER/.config/datum-relay/<instance>.config.json
# Independent advertiser co-signer (recommended) — leave ADVERTISER_PRIVATE_KEY empty:
ADVERTISER_PRIVATE_KEY=
ADVERTISER_COSIGNER_URL=http://127.0.0.1:3402
ADVERTISER_COSIGNER_SECRET=...   # must equal the co-signer's COSIGN_SECRET
CLAIM_BATCH_SIZE=1               # Paseo dual-sig per-tx weight cap
MAX_INFLIGHT=25
LOG_LEVEL=1
# NOTE: set ADVERTISER_PRIVATE_KEY= (empty) explicitly so a stray relay/.env in the
# working dir can't leak an advertiser key and bypass the independent co-signer.
