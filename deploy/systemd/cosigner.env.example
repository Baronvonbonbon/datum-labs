# ~/.config/datum-relay/<instance>.env  (chmod 600 — holds a private key)
# Used by datum-cosigner@<instance>.service.
ADVERTISER_PRIVATE_KEY=0x...     # the advertiser's key (or its advertiser-relay-signer)
HTTP_PORT=3402
COSIGN_SECRET=...                # must equal the relay's ADVERTISER_COSIGNER_SECRET
# Optional policy:
# CAMPAIGN_ALLOWLIST=158,169
# MAX_CPM_PLANCK=0
